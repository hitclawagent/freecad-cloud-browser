    <!--[ Info ]―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――-->

    <name>FreeCAD Cloud Browser</name>
    <description>Browse and open files from cloud storage (Google Drive, Dropbox, OneDrive, Amazon S3, FTP/SFTP, WebDAV/Nextcloud) directly from FreeCAD — no manual download/upload needed. Supports OAuth2, access-key, and username/password authentication depending on the provider.</description>

    <!--[ Tags ]―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――-->

    <tag>cloud</tag>
    <tag>storage</tag>
    <tag>google-drive</tag>
    <tag>dropbox</tag>
    <tag>onedrive</tag>
    <tag>s3</tag>
    <tag>ftp</tag>
    <tag>sftp</tag>
    <tag>webdav</tag>
    <tag>nextcloud</tag>
    <tag>browser</tag>

    <!--[ Maintainers ]――――――――――――――――――――――――――――――――――――――――――――――――――――――-->

