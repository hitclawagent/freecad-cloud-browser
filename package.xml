    <!--[ Urls ]―――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――-->

    <url
        branch = 'main'
        type = 'repository'
    >https://github.com/hitclawagent/freecad-cloud-browser</url>

    <url
        type = 'bugtracker'
    >https://github.com/hitclawagent/freecad-cloud-browser/issues</url>

    <url
        type = 'readme'
    >https://github.com/hitclawagent/freecad-cloud-browser/blob/main/README.md</url>

    <!--[ Python dependencies ]――――――――――――――――――――――――――――――――――――――――――――――-->
    <!-- Core: always required -->
    <depend type = 'python'>requests</depend>

    <!-- Google Drive -->
    <depend type = 'python'>google-api-python-client</depend>
    <depend type = 'python'>google-auth-httplib2</depend>
    <depend type = 'python'>google-auth-oauthlib</depend>

    <!-- Dropbox -->
    <depend type = 'python'>dropbox</depend>

    <!-- OneDrive -->
    <depend type = 'python'>msal</depend>

    <!-- Amazon S3 -->
    <depend type = 'python'>boto3</depend>

    <!-- SFTP -->
    <depend type = 'python'>paramiko</depend>

    <!-- WebDAV -->
    <depend type = 'python'>webdavclient3</depend>

    <!-- Secure credential storage (optional but recommended) -->
    <depend type = 'python'>keyring</depend>
    <depend type = 'python'>cryptography</depend>

    <!--[ Content ]――――――――――――――――――――――――――――――――――――――――――――――――――――――――――-->

    <content>
        <workbench>
            <subdirectory>.</subdirectory>
            <classname>CloudBrowserWorkbench</classname>
            <icon>resources/icons/cloud_browser.svg</icon>
        </workbench>
    </content>

</package>
